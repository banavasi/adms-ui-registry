@fortawesome:registry=https://npm.fontawesome.com/
@awesome.me:registry=https://npm.fontawesome.com/
# Font Awesome Pro auth token must NOT live here: pnpm refuses to expand env vars
# in registry credentials that come from a committed project .npmrc. Put it in your
# user-level ~/.npmrc instead (CI writes it from the FONTAWESOME_NPM_AUTH_TOKEN secret):
#   echo "//npm.fontawesome.com/:_authToken=YOUR_TOKEN" >> ~/.npmrc
registry=https://npm.edpl.us/
